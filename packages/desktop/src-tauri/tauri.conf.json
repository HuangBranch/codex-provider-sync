{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Provider Sync",
  "version": "0.1.0",
  "identifier": "com.huangch.codexprovidersync",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Provider Sync",
        "width": 1100,
        "height": 820,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"]
  }
}
